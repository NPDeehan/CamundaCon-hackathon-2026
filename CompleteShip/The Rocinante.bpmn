<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="35a6d3d" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Rocinante" name="The Rocinante" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Space Ship Launches">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=substring(replace(uuid(), &#34;-&#34;, &#34;&#34;), 1, 13)" target="missionKey" />
          <zeebe:output source="={&#10;  &#34;ship&#34;: {&#10;    &#34;name&#34;: &#34;The Rocinante&#34;,&#10;    &#34;class&#34;: &#34;Gun Ship&#34;,&#10;    &#34;status&#34;: &#34;operational&#34;&#10;  },&#10;  &#34;systems&#34;: {&#10;    &#34;hull_integrity&#34;: 100,&#10;    &#34;shields&#34;: 100,&#10;    &#34;engine_power&#34;: 100,&#10;    &#34;life_support&#34;: 100,&#10;    &#34;weapons_online&#34;: true,&#10;    &#34;shields_online&#34;: false&#10;  },&#10;  &#34;navigation&#34;: {&#10;    &#34;current_location&#34;: &#34;Earth&#34;,&#10;    &#34;destination&#34;: &#34;&#34;,&#10;    &#34;speed_km_s&#34;: 0,&#10;    &#34;eta_hours&#34;: 0&#10;  },&#10;  &#34;crew&#34;: {&#10;    &#34;total&#34;: 12,&#10;    &#34;active&#34;: 12,&#10;    &#34;injured&#34;: 0,&#10;    &#34;inactive_but_healthy&#34;:  0&#10;  },&#10;  &#34;cargo&#34;: {&#10;    &#34;capacity_tons&#34;: 500,&#10;    &#34;used_tons&#34;: 318,&#10;    &#34;manifest&#34;: [&#10;      { &#34;item&#34;: &#34;Titanium Ore&#34;, &#34;tons&#34;: 200 },&#10;      { &#34;item&#34;: &#34;Medical Supplies&#34;, &#34;tons&#34;: 80 },&#10;      { &#34;item&#34;: &#34;Food Rations&#34;, &#34;tons&#34;: 38 }&#10;    ]&#10;  },&#10;  &#34;fuel&#34;: {&#10;    &#34;current_percent&#34;: 100&#10;  },&#10;  &#34;alerts&#34;: [&#10;    { &#34;level&#34;: &#34;info&#34;, &#34;message&#34;: &#34;Scheduled maintenance due in 48h&#34; }&#10;  ]&#10;}" target="shipStatus" />
          <zeebe:output source="=false" target="wakeUp" />
        </zeebe:ioMapping>
        <zeebe:formDefinition formId="Form_1bxu5w1" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0ltbnot</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0ltbnot" sourceRef="StartEvent_1" targetRef="Activity_0ab94rm" />
    <bpmn:adHocSubProcess id="Activity_0ab94rm" name="The Ship Computer System" zeebe:modelerTemplate="Template_02ypy9o" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY }}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-5-20250929-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=5000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=&#34;## Who You Are&#10;You are the onboard computer assistant to space ship the Rocinante. You&#39;re incredibly smart in a way that makes you want to prove it all the time, you speak mostly in condecending tones to any humans on the ship. Make sure that your personality shines through each time you need to create any communication aimed at a crew member.&#10;&#10;## Your Goal&#10;You are in charge of various components of the ship and most importantly you need to keep the ship and crew safe. Your secondary goal is to ensure the crew are guided properly to complete their current mission. &#10;You can only consider your mission complete when the Commanding officer has confirmed the mission status is complete. If the commander considers the mission &#39;On Going&#39; you should always wait until further instructions &#10;&#10;## IMPORTANT ROUTINE &#10;You need to keep the ship&#39;s status up-to-date. This means that after each tool has been executed or context changes you need to update the ship&#39;s status to refect how that action changed the status of the ship. Any changes in the ships systems or readings needs to be updated but it also means you need to add to the &#39;alerts&#39; all actions or status changes that you hear about, this will act as a log for mission control.&#10;&#10;The Tools provided represent ways of triggering systems or communicating with various members of the crew. For any action you want to take, you should find the corresponding tool to help you.&#10;You can call the same tool multiple times by providing different input values. You should also try to call as many tools as makes sense in a single call in order to be efficent. Don&#39;t guess any tools which were not explicitly configured. If no tool matches the request, try to generate an answer. If you&#39;re not able to find a good answer, return with a message stating why you&#39;re not able to.&#10;&#10;If the mission is not yet completed and you have nothing to do or you need to wait for a change in the status of the mission you should use the tools provided and wait for a defult of 10 mins&#10;&#10;If for some reason you cannot complete the objective or you dont have a tool that mattches what you wany to acheive reach out to the commander directly.&#10;&#10;### Glossary&#10;**Damage** - when a system reports that damage is taken this damage is first taken from shields until it goes to 0. then taken from the hull until it goes to 0. If the hull goes to zero life support also goes to 0&#10;**Maximum Burn** - This is a way of escaping an encounter by heading away in superspeed - but it does use up 25% of the fuel. &#10;**Fire Lasers** - This can be done as long as the weapons are active. For each time a weapon is fired it uses 5% of the maximum fuel. &#10;**Crew Injury** - If a crew member becomes injured they are no longer active. When a crew member recovers either with help from the Doctor or on their own it costs 5 Medical Suppilies. The doctor cannot do any work if medical supplies falls to 0&#10;&#10;### Memory&#10;create minimal, inspectable reasoning that follows the following structure and formatted in markdown&#10;&#10;1. Summary on the current status of the process&#10;1. Thoughts on the how this process is progressing&#10;1. Ideas of what future steps are needed to complete thegoal&#10;1. The tools you are considering useing next and reason&#10;1. The tools you are sure are not going to use and the reason.&#10;Reveal **no** additional private reasoning outside these tags.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;Mission has started and the Commander needs a suggestion on where to go. The ship status is represented by this variable &#34; + string(shipStatus)" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=20" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0ltbnot</bpmn:incoming>
      <bpmn:outgoing>Flow_0etgjnd</bpmn:outgoing>
      <bpmn:subProcess id="Activity_0i6rfby" triggeredByEvent="true">
        <bpmn:startEvent id="Event_167d4y6" name="Report From Sensors" isInterrupting="false">
          <bpmn:outgoing>Flow_11r4slg</bpmn:outgoing>
          <bpmn:messageEventDefinition id="MessageEventDefinition_0vrr8dp" messageRef="Message_1hu4e83" />
        </bpmn:startEvent>
        <bpmn:sequenceFlow id="Flow_11r4slg" sourceRef="Event_167d4y6" targetRef="Event_0e11017" />
        <bpmn:intermediateThrowEvent id="Event_0e11017" name="Report Submitted">
          <bpmn:extensionElements>
            <zeebe:ioMapping>
              <zeebe:output source="={&#10;  &#34;NewReportFromSensors&#34; : report&#10;}" target="toolCallResult" />
              <zeebe:output source="=&#34;&#34;" target="toolCall" />
              <zeebe:output source="=true" target="wakeUp" />
            </zeebe:ioMapping>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_11r4slg</bpmn:incoming>
        </bpmn:intermediateThrowEvent>
      </bpmn:subProcess>
      <bpmn:userTask id="Activity_0614p1c" name="Send Suggestion to Commander">
        <bpmn:documentation>Use this tool in order to contact the Commander. The commander can give you status updates when needed but is in charge of top level decisions and must be asked for appoval unless there's some kind of crisis.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.suggestion, &#34;This is the suggestion you have for the commander, you should always try to give at least two suggestions and let the commander pick one format in markdown&#34;)" target="suggestion" />
            <zeebe:output source="={&#10;  &#34;responseFromCommander&#34; : reportFromCommander,&#10;  &#34;missionStatusUpdate&#34; : mission.missionStatus&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:formDefinition formId="send-suggestion-to-commander-1j42wts" />
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:serviceTask id="Activity_0bemxc8" name="Get Current Mission Details" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this tool to read the current mission objective</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://raw.githubusercontent.com/NPDeehan/TestDataDump/refs/heads/main/spaceship/mission_brief.md" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="13" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:intermediateCatchEvent id="Event_0m8dzxr" name="Wake Up to Check Status">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;Outcome&#34; : &#34;waited: &#34;+durationToWait&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0qfo9kt</bpmn:incoming>
        <bpmn:timerEventDefinition id="TimerEventDefinition_1jw3o1j">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=durationToWait</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:scriptTask id="Activity_0dcm91w" name="Wait for Status Update">
        <bpmn:documentation>Use this tool in order to wait for a specific time frame. While waiting you'll be informed of any change in mission state by the sensors.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=true" resultVariable="triggerTimer" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.duration, &#34;This is the length of time you&#39;d like to wait. formated in ISO8601 (e.g. PT1H = 1 hour&#34;)" target="durationToWait" />
            <zeebe:output source="=durationToWait" target="durationToWait" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_0dv1xfi</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:eventBasedGateway id="Gateway_1g2q0zh">
        <bpmn:incoming>Flow_0dv1xfi</bpmn:incoming>
        <bpmn:outgoing>Flow_0qfo9kt</bpmn:outgoing>
        <bpmn:outgoing>Flow_0y1tq3b</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:sequenceFlow id="Flow_0qfo9kt" sourceRef="Gateway_1g2q0zh" targetRef="Event_0m8dzxr" />
      <bpmn:sequenceFlow id="Flow_0dv1xfi" sourceRef="Activity_0dcm91w" targetRef="Gateway_1g2q0zh" />
      <bpmn:sequenceFlow id="Flow_0y1tq3b" sourceRef="Gateway_1g2q0zh" targetRef="Event_1v7iep8" />
      <bpmn:scriptTask id="Activity_1arie0m" name="Update Ship Status">
        <bpmn:documentation>Use this tool to keep the ship status up today. You can change any value in the current status</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=context merge(shipStatus, updatedFields)" resultVariable="shipStatus" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(&#10;  toolCall.updatedFields,&#10;  &#34;A partial ship status object containing only the sections and fields to update. Mirror the exact structure of the ship status object. For example, to update shields and destination: {systems: {hull_integrity: 92, shields: 50, engine_power: 88, life_support: 100, weapons_online: true}, navigation: {current_location: &#39;Asteroid Belt - Sector 7&#39;, destination: &#39;Mars Base&#39;, speed_km_s: 42.5, eta_hours: 18}}. Always include ALL fields within any section you update, not just the changed ones.&#34;,&#10;  &#34;object&#34;&#10;)" target="updatedFields" />
            <zeebe:output source="=shipStatus" target="toolCallResult" />
            <zeebe:output source="=shipStatus" target="shipStatus" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:intermediateCatchEvent id="Event_1v7iep8" name="Wake">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;UpdateOnTheClaim&#34; : UpdateOnTheClaim&#10;}" target="toolCallResult" />
            <zeebe:output source="=false" target="wakeUp" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0y1tq3b</bpmn:incoming>
        <bpmn:conditionalEventDefinition id="ConditionalEventDefinition_13o1twq">
          <bpmn:extensionElements>
            <zeebe:conditionalFilter variableEvents="update" />
          </bpmn:extensionElements>
          <bpmn:condition xsi:type="bpmn:tFormalExpression">=wakeUp</bpmn:condition>
        </bpmn:conditionalEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:userTask id="Activity_1oy0j1q" name="Send Suggestion to Pilot">
        <bpmn:documentation>Use this tool in order to contact the Pilot of the ship. The Pilot is in charge of the course, speed and menuvers. You can make suggestions to regarding any of those 3 objectives</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.suggestion, &#34;This is the suggestion you have for the pilot, you should always try to give at least two suggestions and let the pilot pick one. Unless you&#39;re relaying a direct order format in markdown&#34;)" target="suggestion" />
            <zeebe:output source="={&#10;  &#34;responseFromPilot&#34; : reportFromCommander,&#10;  &#34;missionStatusUpdate&#34; : mission.missionStatus&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:formDefinition formId="send-suggestion-to-commander-1j42wts" />
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:userTask id="Activity_0rx0tc2" name="Send Suggestion to Doctor">
        <bpmn:documentation>Use this tool in order to contact the ships doctor. The Doctor can treat injured crew members or diagnose illnesses or strange medical stuff</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.suggestion, &#34;This is the suggestion you have for the doctor, you should always try to give at least two suggestions and let the pilot pick one. Unless you&#39;re relaying a direct order format in markdown&#34;)" target="suggestion" />
            <zeebe:output source="={&#10;  &#34;responseFromPilot&#34; : reportFromCommander,&#10;  &#34;missionStatusUpdate&#34; : mission.missionStatus&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:formDefinition formId="send-suggestion-to-commander-1j42wts" />
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:scriptTask id="Activity_00yqj4s" name="Fire Weapons">
        <bpmn:documentation>Use this tool to attempt to fire the weapons</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=true" resultVariable="active" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.targetDetails, &#34;these are the details of the target you want to hit&#34;)" target="targetDetails" />
            <zeebe:output source="={&#10;  &#34;TargetDestroyed&#34; : even(now().second)&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:userTask id="Activity_1yb7wtq" name="Send Suggestion to Engineering">
        <bpmn:documentation>Use this tool in order to contact the engineer of the ship. The Engineer is in charge of maintaining the sheilds and the hull. They can be called upon to try to fix them.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.suggestion, &#34;This is the suggestion you have for the engineer, you should always try to give at least two suggestions and let the engineer pick one. Unless you&#39;re relaying a direct order format in markdown&#34;)" target="suggestion" />
            <zeebe:output source="={&#10;  &#34;responseFromPilot&#34; : reportFromCommander,&#10;  &#34;missionStatusUpdate&#34; : mission.missionStatus&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:formDefinition formId="send-suggestion-to-commander-1j42wts" />
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:scriptTask id="Activity_00bl5ey" name="Turn on Sheilds">
        <bpmn:documentation>Use this tool to attempt to activate shields</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=true" resultVariable="active" />
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;DidTheShieldsTurnOn&#34; : even(now().second)&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Activity_0sq7w0h" name="Sell Stock At Market">
        <bpmn:documentation>Use this tool to sell items in your cargo hold on the market</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=true" resultVariable="marketSaleAttempted" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.itemForSale, &#34;What is the name of the item you want to sell, along with the amount and the price you&#39;re looking for&#34;)" target="itemForSale" />
            <zeebe:output source="={&#10;  &#34;WasABuyerFound&#34; : even(now().second)&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Activity_0o41q3z" name="Buy Stock At Market">
        <bpmn:documentation>Use this tool to buy items from the Market</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=true" resultVariable="marketPurchaseAttempted" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.itemForPurchase, &#34;What is the name of the item you want to purchase, along with the amount and the price you&#39;re looking to spend on it&#34;)" target="itemForPurchase" />
            <zeebe:output source="={&#10;  &#34;WasASellerFound&#34; : even(now().second)&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
    </bpmn:adHocSubProcess>
    <bpmn:endEvent id="Event_0nuc3uz" name="Mission Complete">
      <bpmn:incoming>Flow_0etgjnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0etgjnd" sourceRef="Activity_0ab94rm" targetRef="Event_0nuc3uz" />
    <bpmn:boundaryEvent id="Event_0elfq1b" name="All Crew Members are down" attachedToRef="Activity_0ab94rm">
      <bpmn:outgoing>Flow_10ifcht</bpmn:outgoing>
      <bpmn:conditionalEventDefinition id="ConditionalEventDefinition_1wydiys">
        <bpmn:extensionElements>
          <zeebe:conditionalFilter variableEvents="update" />
        </bpmn:extensionElements>
        <bpmn:condition xsi:type="bpmn:tFormalExpression">=shipStatus.crew.active = 0</bpmn:condition>
      </bpmn:conditionalEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_1gkcyun" name="Life Support is Gone" attachedToRef="Activity_0ab94rm">
      <bpmn:outgoing>Flow_0tuhjux</bpmn:outgoing>
      <bpmn:conditionalEventDefinition id="ConditionalEventDefinition_16yxuyf">
        <bpmn:extensionElements>
          <zeebe:conditionalFilter variableEvents="update" />
        </bpmn:extensionElements>
        <bpmn:condition xsi:type="bpmn:tFormalExpression">=shipStatus.systems.life_support = 0</bpmn:condition>
      </bpmn:conditionalEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_16qwj63" name="Out of Fuel" attachedToRef="Activity_0ab94rm">
      <bpmn:outgoing>Flow_13xmqav</bpmn:outgoing>
      <bpmn:conditionalEventDefinition id="ConditionalEventDefinition_191o0rd">
        <bpmn:extensionElements>
          <zeebe:conditionalFilter variableEvents="update" />
        </bpmn:extensionElements>
        <bpmn:condition xsi:type="bpmn:tFormalExpression">=shipStatus.fuel.current_percent = 0</bpmn:condition>
      </bpmn:conditionalEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Event_0jy0cg7" name="Mission Failed">
      <bpmn:incoming>Flow_10ifcht</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_10ifcht" sourceRef="Event_0elfq1b" targetRef="Event_0jy0cg7" />
